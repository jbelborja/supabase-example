# Copy this to .env.docker and keep it local (never commit .env.docker)
#
# These are the well-known LOCAL dev keys used by the Supabase CLI.
# They are safe to use for local development only.
#
# After `docker compose --env-file .env.docker up -d`, set your .env.local:
#   VITE_SUPABASE_URL=http://localhost:8000
#   VITE_SUPABASE_ANON_KEY=<ANON_KEY below>

POSTGRES_PASSWORD=postgres

# Must be at least 32 characters
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Pre-generated JWTs signed with the JWT_SECRET above
# role: anon  — used by the frontend
